{
  "name": "perps-trader",
  "version": "2.0.0",
  "description": "Agent-first modular AI trading floor for Hyperliquid — robust agents with tunable parameters",
  "main": "bin/main.js",
  "scripts": {
    "start": "node bin/main.js",
    "start:predictions": "node bin/prediction-agent.js",
    "start:pumpfun": "node bin/pumpfun-agent/index.js",
    "start:news-agent": "node bin/news-agent.js",
    "start:dashboard": "node bin/main.js --dashboard-only",
    "wallets:setup": "ts-node src/safekeeping-fund/wallet-setup.ts",
    "wallets:openclaw": "node scripts/openclaw-wallets.js addresses",
    "wallets:openclaw:env": "node scripts/openclaw-wallets.js export-env",
    "dev": "node --watch bin/main.js",
    "build": "npm run build:esbuild && npm run build:cli",
    "build:esbuild": "npx esbuild src/main.ts --bundle --platform=node --outfile=bin/main.js --format=cjs --external:better-sqlite3 --external:sharp --external:sqlite3 --external:pino-pretty && npx esbuild src/news-agent/index.ts --bundle --platform=node --outfile=bin/news-agent.js --format=cjs --external:better-sqlite3 --external:sharp --external:sqlite3 --external:pino-pretty && npx esbuild src/prediction-agent.ts --bundle --platform=node --outfile=bin/prediction-agent.js --format=cjs --external:better-sqlite3 --external:sharp --external:sqlite3 --external:pino-pretty && npx esbuild src/tui/index.tsx --bundle --platform=node --outfile=bin/perps-tui.js --format=cjs --jsx=automatic --external:better-sqlite3 --external:sharp --external:sqlite3 --external:pino-pretty",
    "build:cli": "npx esbuild src/cli/perps-cli.ts --bundle --platform=node --outfile=bin/perps.js --format=cjs",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/test.sh",
    "test:unit": "jest --runInBand",
    "test:ingestion": "ts-node scripts/test-ingestion-reliability.ts",
    "test:redis": "ts-node src/scripts/test-redis.ts",
    "lint": "eslint src/**/*.ts",
    "setup": "npm install && npm run build",
    "setup:enhanced": "bash scripts/setup-enhanced-clustering.sh",
    "migrate:002": "bash migrations/run-002.sh",
    "migrate:evolution": "sqlite3 data/trading.db < database/schema/evolution.sql",
    "research:worker": "node bin/backtest-worker/index.js",
    "research:evolve": "node bin/evolution-engine/index.js",
    "research:evolve:verbose": "node bin/evolution-engine/index.js --verbose",
    "tui": "node bin/perps-tui.js",
    "tui:dev": "tsx src/tui/index.tsx",
    "tui:build": "tsc --outDir ./bin --project tsconfig.json"
  },
  "bin": {
    "perps-tui": "bin/perps-tui.js",
    "perps": "./bin/perps.js"
  },
  "dependencies": {
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.0.7",
    "@langchain/openai": "^1.2.0",
    "@nktkas/hyperliquid": "^0.17.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.0",
    "@types/commander": "^2.12.0",
    "@uniswap/sdk-core": "^7.10.1",
    "@uniswap/v3-sdk": "^3.27.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^9.2.2",
    "bs58": "^6.0.0",
    "bullmq": "^5.66.4",
    "ccxt": "^4.1.48",
    "chalk": "^4.1.2",
    "chromadb": "^3.2.0",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ink": "^3.2.0",
    "ioredis": "^5.9.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.66.0",
    "ox": "0.11.3",
    "pino": "^10.3.1",
    "react": "^17.0.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.6",
    "technicalindicators": "^3.1.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.1",
    "viem": "^2.21.0",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.8",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.19.27",
    "@types/react": "^17.0.91",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "trading",
    "ai",
    "hyperliquid",
    "cryptocurrency",
    "defi"
  ],
  "author": "PerpsTrader AI",
  "license": "MIT"
}
